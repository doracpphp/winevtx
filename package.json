{
  "name": "winevtx",
  "version": "0.1.0",
  "description": "Pure JavaScript Windows EVTX (Event Log) parser for Node.js and browsers",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/cli.ts"
  ],
  "scripts": {
    "build": "tsc",
    "parse": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "evtx",
    "windows",
    "event-log",
    "parser",
    "forensics",
    "binxml"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/doracpphp/winevtx"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
